# 服务端口
PORT=8080

# PostgreSQL 数据库
DATABASE_URL=postgres://mengxuegushi:mengxuegushi@127.0.0.1:5432/mengxuegushi

# 音频目录；可以指向小程序项目里的 audios 目录
AUDIO_DIR=/path/to/workspace/mengxue-gushi/audios

# 对外访问根地址；本地开发可留空，后端会返回 /audios/poem-x.mp3 和 /images/poem-x.jpg
PUBLIC_BASE_URL=

# 开发期登录接口；生产环境建议设为 false
ENABLE_DEV_LOGIN=true

# 微信小程序配置；不要提交真实密钥
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# 日志级别示例
RUST_LOG=mengxuegushi_rust=debug,tower_http=debug,axum=debug
